# Credentials contract for the Network Forensics Toolkit
# ──────────────────────────────────────────────────────────
# Phase 1 (Invoke-BotnetTriage) is OFFLINE — none of these keys are read.
# They are committed empty now so operators can populate `.env` (gitignored)
# ahead of Phase 2 (Invoke-C2BeaconHunt), which performs threat-intel
# enrichment against these services.
#
# Copy this file to `.env` and fill in values. Never commit `.env`.

# ── VirusTotal ──
VT_API_KEY=

# ── AbuseIPDB ──
ABUSEIPDB_API_KEY=

# ── Scamalytics ──
SCAMALYTICS_USERNAME=
SCAMALYTICS_API_KEY=

# ── ip-api.com (free tier, no key required) ──
# IPAPI_KEY=
